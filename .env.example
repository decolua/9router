# 9Router environment contract
# This file reflects actual runtime usage in the current codebase.

# Required
JWT_SECRET=change-me-to-a-long-random-secret
INITIAL_PASSWORD=change-me
DATA_DIR=./data
# Database: when set, app uses PostgreSQL instead of local JSON file.
# Dev: use docker compose up -d then DATABASE_URL=postgres://9router:9router@localhost:5432/9router
DATABASE_URL=postgres://9router:9router@localhost:5432/9router
# Optional: max connections per process (default 3). Lower if you see "too many clients already".
PG_POOL_MAX=3

# Recommended runtime variables
PORT=20128
NODE_ENV=production

# Recommended security and ops variables
API_KEY_SECRET=endpoint-proxy-api-key-secret
MACHINE_ID_SALT=endpoint-proxy-salt
ENABLE_REQUEST_LOGS=false
OBSERVABILITY_ENABLED=true
AUTH_COOKIE_SECURE=false
REQUIRE_API_KEY=false

# Multi-user and Microsoft OAuth (dashboard login)
# When USE_MICROSOFT_OAUTH=true and client id (and secret if not public) are set, login page shows "Sign in with Microsoft"
USE_MICROSOFT_OAUTH=true
MICROSOFT_CLIENT_ID=699f561f-c753-4ee3-be32-24f35a8f90d4
# MICROSOFT_CLIENT_SECRET=zgQ8Q~4eamMyMs2Qo6_DsJ4sIr0Mya~qvUPtIa~H
# Set to true if app is registered as "public client" (SPA). Then token exchange runs in the browser.
MICROSOFT_PUBLIC_CLIENT=true
# In Azure Portal → App registration → Authentication → Single-page application → Add redirect URI:
#   Dev:  http://localhost:20128/login/callback
#   Prod: https://your-domain/login/callback
# Override redirect URI if needed (must match exactly what is in Azure):
# MICROSOFT_REDIRECT_URI=http://localhost:20128/login/callback
# Optional: AZURE_AD_CLIENT_ID / AZURE_AD_CLIENT_SECRET are also read
# Optional: tenant for single-tenant app (default "common" for multi-tenant)
MICROSOFT_TENANT_ID=1fd983f3-dc44-42f8-ad66-7972e9d94659
# Email used when creating user on password login (no Microsoft)
DEFAULT_USER_EMAIL=long.le@eastgate-software.com
# Comma-separated emails that get isAdmin=true (e.g. team leads)
# ADMIN_EMAILS=admin@example.com,lead@example.com

# Cloud sync variables
# Must point to this running instance so internal sync jobs can call /api/sync/cloud.
# Server-side preferred variables:
BASE_URL=http://localhost:20128
CLOUD_URL=https://9router.com
# Backward-compatible/public variables:
NEXT_PUBLIC_BASE_URL=http://localhost:20128
NEXT_PUBLIC_CLOUD_URL=https://9router.com

# Optional outbound proxy variables for upstream provider calls
# Lowercase variants are also supported: http_proxy, https_proxy, all_proxy, no_proxy
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# Currently unused by application runtime (kept as reference)
# INSTANCE_NAME=9router
