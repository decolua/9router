# EGS Proxy AI environment contract
# Copy to .env and set at least the "Required" section.

# ========== BẮT BUỘC (Required) ==========
# App dùng PostgreSQL; không có fallback file.
DATABASE_URL=postgres://egs_proxy_ai:egs_proxy_ai@localhost:5432/egs_proxy_ai
# Bảo mật session dashboard — production phải đổi.
JWT_SECRET=change-me-to-a-long-random-secret
# Mật khẩu đăng nhập lần đầu / tạo user (production phải đổi).
INITIAL_PASSWORD=change-me

# ========== KHUYẾN NGHỊ (Recommended) ==========
PORT=20128
NODE_ENV=production
# Thư mục data (usage, tunnel state). Docker: /app/data
DATA_DIR=./data
# Số connection Postgres tối đa (mặc định 3)
# PG_POOL_MAX=3
# API key / machineId — nên set nếu production
# API_KEY_SECRET=endpoint-proxy-api-key-secret
# MACHINE_ID_SALT=endpoint-proxy-salt
# Có bắt API key cho /v1/* không (false = cho phép gọi không key)
# REQUIRE_API_KEY=false
# Cookie secure (true khi chạy HTTPS)
# AUTH_COOKIE_SECURE=false
# URL app — dùng cho OAuth callback, link trong email, v.v.
BASE_URL=http://localhost:20128
NEXT_PUBLIC_BASE_URL=http://localhost:20128

# ========== TÙY CHỌN — CHỈ KHI DÙNG TÍNH NĂNG ==========

# --- Tunnel (Cloudflare) — chỉ khi admin bật tunnel từ Dashboard
# Mặc định đã đủ; chỉ set nếu dùng custom domain hoặc self-host tunnel backend.
# TUNNEL_WORKER_URL=https://tunnel.egsproxy.ai
# TUNNEL_CUSTOM_DOMAIN=eastgate-software.com
# TUNNEL_SUBDOMAIN=tunnel

# --- Microsoft OAuth (đăng nhập "Sign in with Microsoft") — chỉ khi bật
# USE_MICROSOFT_OAUTH=true
# MICROSOFT_CLIENT_ID=your-client-id
# MICROSOFT_CLIENT_SECRET=your-secret
# MICROSOFT_PUBLIC_CLIENT=true
# MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=http://localhost:20128/login/callback
# Email được coi là admin (isAdmin=true)
# ADMIN_EMAILS=admin@example.com

# --- Cloud sync — hiện đã tắt (ưu tiên Tunnel). Chỉ cần nếu bật lại Cloud Worker.
# CLOUD_URL=https://your-worker.workers.dev
# NEXT_PUBLIC_CLOUD_URL=https://your-worker.workers.dev

# --- Email (thông báo đăng ký chờ duyệt, v.v.) — chỉ khi cần gửi mail
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=EGS Proxy AI <noreply@yourdomain.com>
# Hoặc SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=EGS Proxy AI <noreply@yourdomain.com>
# NOTIFY_ADMIN_EMAILS=admin@example.com

# --- Outbound proxy (gọi upstream provider qua proxy)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1

# --- Khác
# ENABLE_REQUEST_LOGS=false
# OBSERVABILITY_ENABLED=true
# REQUIRE_LOGIN=true
# DEFAULT_USER_EMAIL=user@example.com
